{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": ["vite/client"]
  },
  "include": ["src/server/**/*", "client/src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "client/dist", "src/__tests__/**/*"]
}
