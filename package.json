{
  "name": "trueque-canarias-social",
  "version": "1.0.0",
  "description": "Trueque Canarias Social - MVP",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"yarn dev:server\" \"yarn dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "typecheck": "tsc --noEmit",
    "check:types": "tsc --noEmit",
    "build": "yarn build:client && yarn build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:generate-seed": "tsx database/generate-seed.ts",
    "db:seed": "tsx database/seed.ts",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose stop postgres"
  },
  "dependencies": {
    "@trpc/client": "^10.44.0",
    "@trpc/server": "^10.44.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2",
    "trpc-openapi": "^1.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "5.4.14",
    "vitest": "^1.2.0"
  }
}
